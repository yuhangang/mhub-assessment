{
  "name": "mhub-workflow",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone MHUB workflow engine with PostgreSQL and a simple admin dashboard.",
  "main": "dist/server.js",
  "scripts": {
    "build": "next build && tsc -p tsconfig.backend.json",
    "start": "node dist/server.js",
    "dev:backend": "PORT=3001 ts-node-dev --respawn --transpile-only --project tsconfig.backend.json src/server.ts",
    "dev:frontend": "next dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "test": "jest --runInBand",
    "db:setup": "psql \"$DATABASE_URL\" -f db/schema.sql && psql \"$DATABASE_URL\" -f db/seed.sql"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "next": "^14.2.4",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
